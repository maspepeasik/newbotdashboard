# ============================================================
# PentestBot v2 — Environment Configuration
# Copy to .env and populate with your credentials.
# NEVER commit .env to version control.
# ============================================================

# ── Telegram (required) ───────────────────────────────────────
# Obtain from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=8701693765:AAEGCRPft2VBtAnLwG6sq8TplQmPGFp9UtM

# ── Groq AI (required) ────────────────────────────────────────
# Obtain from https://console.groq.com
GROQ_API_KEY=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
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=4096
GROQ_TEMPERATURE=0.2

# ── Access Control ────────────────────────────────────────────
# Comma-separated Telegram numeric user IDs allowed to use the bot.
# Leave EMPTY to allow ALL users (not recommended for production).
# Find your user ID via @userinfobot on Telegram.
# Example: ALLOWED_USER_IDS=123456789,987654321
ALLOWED_USER_IDS=7938352061

# ── Concurrency & Timeouts ────────────────────────────────────
MAX_CONCURRENT_SCANS=3
SCAN_TIMEOUT=3600

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO

# Internal dashboard integration API
PENTESTBOT_API_ENABLED=true
PENTESTBOT_API_HOST=0.0.0.0
PENTESTBOT_API_PORT=8080
# Optional bearer token for internal callers like the dashboard worker
PENTESTBOT_API_TOKEN=b47bc562f096436ce843868429268cca86acbbe5f6cf1971d8341d366b00ff22


# Optional container/runtime path overrides
PENTESTBOT_DATA_DIR=/app/data
PENTESTBOT_LOGS_DIR=/app/logs
PENTESTBOT_REPORTS_DIR=/app/reports
PENTESTBOT_WORK_DIR=/app/data/work
PENTESTBOT_DB_PATH=/app/data/pentestbot.db

# ── Scan Tuning ───────────────────────────────────────────────
# Subfinder
SUBFINDER_THREADS=10

# Naabu port scanning
# NAABU_PORTS — Explicit port list (e.g. 80,443,8080). Leave empty to use top ports.
NAABU_PORTS=
NAABU_TOP_PORTS=1000
NAABU_RATE=1000

# Nmap service detection
NMAP_FLAGS=-sV -sC
NMAP_TIMING=T4

# HTTPX web probing
HTTPX_THREADS=50

# Nuclei vulnerability scanning
NUCLEI_SEVERITY=critical,high,medium,low,info
NUCLEI_RATE_LIMIT=150
# In Docker, the entrypoint bootstraps templates into this path automatically.
NUCLEI_TEMPLATES=/home/pentestbot/.config/nuclei/templates
