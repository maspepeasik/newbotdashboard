# ============================================================
# PentestBot v2 — Environment Configuration
# Docker Compose reads this file automatically.
# NEVER commit this file to version control.
# ============================================================

# ── Public URLs ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=
APP_URL=

# ── Cloudflare Tunnel ─────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=

# ── Groq AI (required) ────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=4096
GROQ_TEMPERATURE=0.2

# ── Telegram (optional — leave empty for API-only mode) ──────
TELEGRAM_BOT_TOKEN=
ALLOWED_USER_IDS=

# ── API Configuration ────────────────────────────────────────
PENTESTBOT_API_TOKEN=b47bc562f096436ce843868429268cca86acbbe5f6cf1971d8341d366b00ff22
CORS_ORIGINS=
ENGINE_PORT=8000
FRONTEND_PORT=3000

# ── Concurrency & Timeouts ───────────────────────────────────
MAX_CONCURRENT_SCANS=3
SCAN_TIMEOUT=3600
LOG_LEVEL=INFO

# ── Container Paths ──────────────────────────────────────────
PENTESTBOT_DATA_DIR=/app/data
PENTESTBOT_LOGS_DIR=/app/logs
PENTESTBOT_REPORTS_DIR=/app/reports
PENTESTBOT_WORK_DIR=/app/data/work
PENTESTBOT_DB_PATH=/app/data/pentestbot.db

# ── Scan Tuning ──────────────────────────────────────────────
SUBFINDER_THREADS=10
NAABU_PORTS=
NAABU_TOP_PORTS=1000
NAABU_RATE=1000
NMAP_FLAGS=-sV -sC
NMAP_TIMING=T4
HTTPX_THREADS=50
NUCLEI_SEVERITY=critical,high,medium
NUCLEI_RATE_LIMIT=150
NUCLEI_TEMPLATES=

# ── Tool Toggles ─────────────────────────────────────────────
# Set to 'true' or 'false' to enable/disable specific tools.
ENABLE_AMASS=true
ENABLE_GOBUSTER=true
ENABLE_DIRSEARCH=true
ENABLE_FINGERPRINT=true
ENABLE_NIKTO=true
ENABLE_WPSCAN=true
ENABLE_JOOMSCAN=true
ENABLE_S3SCANNER=true
ENABLE_SSLYZE=true
ENABLE_WEB_DISCOVERY=true
